/* ════════════════════════════════════════════════
   PDF
   ════════════════════════════════════════════════ */
async function generatePDF() {
  var btn = document.getElementById('dlBtn');
  btn.textContent = 'Generando PDF…';
  btn.disabled = true;

  var jspdf  = window.jspdf;
  var doc    = new jspdf.jsPDF({ orientation:'portrait', unit:'mm', format:'letter' });
  var PW     = 215.9;
  var M      = 18;
  var TW     = PW - M * 2;
  var PH     = doc.internal.pageSize.height;
  var name   = studentData.name;
  var group  = studentData.group;
  var total  = problems.length;
  var pct    = Math.round(correctCount / total * 100);
  var dateStr = new Date().toLocaleString('es-MX', { dateStyle:'long', timeStyle:'short' });

  var raw = name + '|' + group + '|' + correctCount + '|' + total + '|' + new Date().toDateString();
  var h = 0;
  for (var ci = 0; ci < raw.length; ci++) h = (Math.imul(31, h) + raw.charCodeAt(ci)) | 0;
  var code = Math.abs(h).toString(36).toUpperCase().slice(0, 8);

  var pBR = 74,  pBG = 124, pBB = 63;
  var pAR = 201, pAG = 168, pAB = 76;

  function pdfText(html) {
    if (!html) return '';
    return html
      .replace(/<[^>]+>/g,'').replace(/&lt;/g,'<').replace(/&gt;/g,'>').replace(/&amp;/g,'&')
      .replace(/&nbsp;/g,' ').replace(/&#[0-9]+;/g,'')
      .replace(/\u2192/g,'->').replace(/\u2212/g,'-').replace(/\u00b2/g,'^2')
      .replace(/\u00b3/g,'^3').replace(/\u00d7/g,'x').replace(/\u00f7/g,'/')
      .replace(/\u2260/g,'!=').replace(/\u2264/g,'<=').replace(/\u2265/g,'>=')
      .replace(/\u221a/g,'sqrt').replace(/\u03c0/g,'pi').replace(/\u2026/g,'...')
      .replace(/\u03b5/g,'epsilon').replace(/\u03b2/g,'beta')
      .replace(/\s+/g,' ').trim();
  }

  // Portada
  doc.setFillColor(pAR,pAG,pAB); doc.rect(0,0,PW,2,'F');
  doc.setFillColor(255,255,255); doc.rect(0,2,PW,26,'F');
  doc.setFillColor(pAR,pAG,pAB); doc.rect(0,28,PW,2,'F');
  doc.setFillColor(pBR,pBG,pBB); doc.rect(0,30,PW,34,'F');

  // Institution logos
  var logoLeftEl   = document.getElementById('logo-left');
  var logoRightEl  = document.getElementById('logo-right');
  var logoLeftB64  = logoLeftEl  && logoLeftEl.src  ? logoLeftEl.src  : null;
  var logoRightB64 = logoRightEl && logoRightEl.src ? logoRightEl.src : null;
  if (logoLeftB64)  try { doc.addImage(logoLeftB64,  'JPEG', M,   4, 48, 22); } catch(e) {}
  if (logoRightB64) try { doc.addImage(logoRightB64, 'JPEG', 130, 4, 48, 22); } catch(e) {}

  // LIAXA logo
  var lx = PW - M - 36;
  var ly = 10;
  doc.setDrawColor(pBR,pBG,pBB); doc.setLineWidth(0.7);
  doc.lines([[2.57-1.03,4.63-6.17],[4.11-2.57,5.14-4.63],[5.66-4.11,2.57-5.14]], lx+1.03, ly+6.17);
  doc.setFillColor(pAR,pAG,pAB); doc.circle(lx+5.66, ly+2.57, 0.9, 'F');
  doc.setDrawColor(pAR,pAG,pAB); doc.setLineWidth(0.7);
  doc.line(lx+8.23, ly+1.54, lx+8.23, ly+7.2);
  doc.setTextColor(pBR,pBG,pBB); doc.setFontSize(11); doc.setFont('helvetica','bold');
  doc.text('LIAXA', lx+10, ly+6.8);

  doc.setTextColor(232,238,247); doc.setFontSize(19); doc.setFont('helvetica','bold');
  doc.text('Mi Modelo Econometrico', M, 49);
  doc.setTextColor(150,165,200); doc.setFontSize(8); doc.setFont('helvetica','normal');
  doc.text(dateStr, M, 59);

  // Tarjeta alumno
  doc.setFillColor(237,240,245); doc.roundedRect(M,72,TW,20,3,3,'F');
  doc.setTextColor(130,140,160); doc.setFontSize(8.5); doc.setFont('helvetica','bold');
  doc.text('ALUMNO', M+4, 79); doc.text('GRUPO', 130, 79);
  doc.setTextColor(20,24,32); doc.setFontSize(11); doc.setFont('helvetica','bold');
  doc.text(name, M+4, 87); doc.text(group, 130, 87);

  // Cuadro calificación
  var sc = pct>=70?[26,106,74]:pct>=50?[224,123,26]:[176,48,16];
  doc.setFillColor(255,255,255); doc.roundedRect(M,100,TW,34,4,4,'F');
  doc.setDrawColor(sc[0],sc[1],sc[2]); doc.setLineWidth(0.8);
  doc.roundedRect(M,100,TW,34,4,4,'S');
  doc.setTextColor(sc[0],sc[1],sc[2]); doc.setFontSize(40); doc.setFont('helvetica','bold');
  doc.text(pct+'%', PW/2, 124, {align:'center'});
  doc.setTextColor(130,140,160); doc.setFontSize(8.5); doc.setFont('helvetica','normal');
  doc.text(correctCount+' correcta(s) de '+total+' preguntas', PW/2, 131, {align:'center'});

  // ── Mini-propuesta en PDF ──
  doc.setFillColor(pBR,pBG,pBB); doc.setTextColor(255,255,255);
  doc.setFontSize(7); doc.setFont('helvetica','bold');
  doc.rect(M,142,TW,8,'F'); doc.text('MINI-PROPUESTA DE INVESTIGACIÓN', M+4, 148);
  var py2 = 154;

  var propItems = [
    { label: 'PREGUNTA DE INVESTIGACIÓN', id: 'pq' },
    { label: 'VARIABLE DEPENDIENTE (Y)', id: 'py' },
    { label: 'MODELO FORMAL', el: document.getElementById('modelDisplay') },
    { label: 'LIMITACIÓN PRINCIPAL', id: 'limitation' },
    { label: 'CONCLUSIÓN / RECOMENDACIÓN', id: 'sowhat1' },
    { label: 'AUDIENCIA DEL ESTUDIO', id: 'sowhat2' }
  ];

  propItems.forEach(function(item) {
    if (py2 + 16 > PH - 15) { doc.addPage(); py2 = 20; }
    var val = item.el ? pdfText(item.el.textContent) : pdfText((document.getElementById(item.id)||{value:''}).value);
    doc.setFillColor(245,247,250); doc.roundedRect(M, py2, TW, 14, 2, 2, 'F');
    doc.setTextColor(pBR,pBG,pBB); doc.setFontSize(6); doc.setFont('helvetica','bold');
    doc.text(item.label, M+3, py2+5);
    doc.setTextColor(20,24,32); doc.setFontSize(8); doc.setFont('helvetica','normal');
    var lines = doc.splitTextToSize(val || ', ', TW-6);
    doc.text(lines[0] || ', ', M+3, py2+11);
    py2 += 17;
  });

  // Variables table in PDF
  if (py2 + 30 > PH - 15) { doc.addPage(); py2 = 20; }
  doc.setFillColor(pBR,pBG,pBB); doc.setTextColor(255,255,255);
  doc.setFontSize(6); doc.setFont('helvetica','bold');
  doc.rect(M, py2, TW, 7, 'F');
  doc.text('REGRESORES', M+3, py2+5);
  py2 += 9;
  for (var r = 0; r < 4; r++) {
    var vn = (document.getElementById('vname'+r)||{value:''}).value.trim();
    if (!vn) continue;
    if (py2 + 8 > PH - 15) { doc.addPage(); py2 = 20; }
    var vs = (document.getElementById('vsign'+r)||{value:'+'}).value;
    var vsr = (document.getElementById('vsrc'+r)||{value:''}).value.trim();
    doc.setFillColor(r%2===0?245:250, r%2===0?247:252, r%2===0?250:255);
    doc.roundedRect(M, py2, TW, 7, 1, 1, 'F');
    doc.setTextColor(20,24,32); doc.setFontSize(7.5); doc.setFont('helvetica','normal');
    doc.text('beta'+(r+1)+' '+vn+' ('+vs+')' + (vsr?', '+vsr:''), M+3, py2+5);
    py2 += 8;
  }

  // Resumen problemas
  py2 += 4;
  if (py2 + 14 > PH - 15) { doc.addPage(); py2 = 20; }
  doc.setFillColor(pBR,pBG,pBB); doc.setTextColor(255,255,255);
  doc.setFontSize(7); doc.setFont('helvetica','bold');
  doc.rect(M,py2,TW,8,'F'); doc.text('RESUMEN DE PREGUNTAS', M+4, py2+6);
  var sy = py2 + 12;
  problems.forEach(function(prob, i) {
    if (sy + 12 > PH - 15) {
      doc.addPage(); sy = 20;
      doc.setFillColor(pBR,pBG,pBB); doc.setTextColor(255,255,255);
      doc.setFontSize(7); doc.setFont('helvetica','bold');
      doc.rect(M,sy,TW,8,'F'); doc.text('RESUMEN DE PREGUNTAS (continuación)', M+4, sy+6);
      sy += 12;
    }
    var ok = document.getElementById('pc'+i).classList.contains('ok');
    doc.setFillColor(ok?232:255, ok?240:232, ok?232:228);
    doc.roundedRect(M,sy,TW,10,2,2,'F');
    doc.setFillColor(ok?26:176, ok?106:48, ok?74:16);
    doc.circle(M+6, sy+5, 2.5, 'F');
    doc.setTextColor(255,255,255); doc.setFontSize(7); doc.setFont('helvetica','bold');
    doc.text(ok?'✓':'✗', M+4.5, sy+6.5);
    doc.setTextColor(20,24,32); doc.setFontSize(8); doc.setFont('helvetica','normal');
    doc.text('Pregunta '+(i+1)+': '+pdfText(prob.title), M+12, sy+6.5);
    doc.setTextColor(ok?26:176, ok?106:48, ok?74:16);
    doc.text(ok?'Correcto':'Incorrecto', PW-M-24, sy+6.5);
    sy += 12;
  });

  // Páginas por problema
  for (var i = 0; i < problems.length; i++) {
    var prob = problems[i];
    doc.addPage();
    var wy = 0;
    doc.setFillColor(pBR,pBG,pBB); doc.rect(0,0,PW,20,'F');
    doc.setFillColor(pAR,pAG,pAB); doc.rect(0,0,PW,3,'F');
    doc.setTextColor(pAR,pAG,pAB); doc.setFontSize(7); doc.setFont('helvetica','normal');
    doc.text('Econometría  ·  Mi Modelo Econométrico', M, 10);
    doc.setTextColor(232,238,247); doc.setFontSize(10.5); doc.setFont('helvetica','bold');
    doc.text('Pregunta '+(i+1)+' de '+total+' ,  '+pdfText(prob.title), M, 17);
    wy = 25;

    var qRaw = pdfText(prob.questionText);
    doc.setFontSize(8.5); doc.setFont('helvetica','normal');
    var qLines = doc.splitTextToSize(qRaw, TW-10);
    var qBoxH  = 8 + qLines.length*5 + 3;
    doc.setFillColor(237,240,245); doc.roundedRect(M,wy,TW,qBoxH,2,2,'F');
    doc.setTextColor(pBR,pBG,pBB); doc.setFontSize(6.5); doc.setFont('helvetica','bold');
    doc.text('PREGUNTA', M+4, wy+6);
    doc.setTextColor(20,24,32); doc.setFontSize(8.5); doc.setFont('helvetica','normal');
    var qy = wy+12;
    qLines.forEach(function(ln,li){ doc.text(ln, M+4, qy+li*5); });
    wy += qBoxH + 4;

    var isOk   = document.getElementById('pc'+i).classList.contains('ok');
    var chosen = prob.studentChoice != null ? pdfText(prob.options[prob.studentChoice]||', ') : ', ';
    var corr   = pdfText(prob.options[prob.correctIdx]||'');
    var expRaw = pdfText(prob.explanation||'');
    doc.setFontSize(8.5); var chLines = doc.splitTextToSize('Alumno: '+chosen, TW-18);
    doc.setFontSize(8);   var coLines = doc.splitTextToSize('Correcto: '+corr, TW-18);
    doc.setFontSize(7.5); var exLines = doc.splitTextToSize('Solución: '+expRaw, TW-18).slice(0,4);
    var ansBoxH = 8 + chLines.length*5.5 + coLines.length*5 + exLines.length*5 + 6;
    doc.setFillColor(isOk?232:255, isOk?240:232, isOk?232:228);
    doc.roundedRect(M,wy,TW,ansBoxH,2,2,'F');
    doc.setFillColor(isOk?26:176, isOk?106:48, isOk?74:16);
    doc.circle(M+7, wy+8, 3.5, 'F');
    doc.setTextColor(255,255,255); doc.setFontSize(9); doc.setFont('helvetica','bold');
    doc.text(isOk?'✓':'✗', M+5.2, wy+10.5);
    var ay = wy+7;
    doc.setTextColor(20,24,32); doc.setFontSize(8.5); doc.setFont('helvetica','bold');
    chLines.forEach(function(ln,li){ doc.text(ln, M+14, ay+li*5.5); });
    ay += chLines.length*5.5 + 3;
    doc.setTextColor(26,106,74); doc.setFontSize(8); doc.setFont('helvetica','normal');
    coLines.forEach(function(ln,li){ doc.text(ln, M+14, ay+li*5); });
    ay += coLines.length*5 + 3;
    doc.setTextColor(90,85,80); doc.setFontSize(7.5);
    exLines.forEach(function(ln,li){ doc.text(ln, M+14, ay+li*5); });
    wy += ansBoxH + 5;

    doc.setFillColor(pBR,pBG,pBB); doc.setTextColor(255,255,255);
    doc.setFontSize(7); doc.setFont('helvetica','bold');
    doc.rect(M,wy,TW,8,'F'); doc.text('TRABAJO DEL ALUMNO', M+4, wy+5.5);
    wy += 11;

    var dc = document.getElementById('dc'+i);
    if (dc) {
      try {
        var imgD = dc.toDataURL('image/png');
        var ar   = dc.height / dc.width;
        var iw   = TW;
        var ih   = Math.min(iw * ar, 68);
        doc.addImage(imgD, 'PNG', M, wy, iw, ih);
        wy += ih + 4;
      } catch(e) {}
    }

    var ta = document.getElementById('ta'+i);
    if (ta && ta.value.trim()) {
      if (wy > PH-30) { doc.addPage(); wy = 20; }
      doc.setTextColor(20,24,32); doc.setFontSize(8); doc.setFont('courier','normal');
      var taLines = doc.splitTextToSize(ta.value, TW);
      taLines.slice(0,16).forEach(function(ln) {
        if (wy > PH-15) { doc.addPage(); wy = 20; }
        doc.text(ln, M, wy); wy += 5;
      });
      wy += 2;
    }

    var pp = document.getElementById('pp'+i);
    if (pp && pp.src && pp.src.indexOf('data:') === 0) {
      if (wy > PH-55) { doc.addPage(); wy = 20; }
      try { doc.addImage(pp.src, 'JPEG', M, wy, TW, 68); wy += 72; } catch(e) {}
    }
  }

  // Pie de página
  var pages = doc.internal.getNumberOfPages();
  for (var p = 1; p <= pages; p++) {
    doc.setPage(p);
    doc.setFillColor(pAR,pAG,pAB); doc.rect(0, PH-3, PW, 3, 'F');
    doc.setTextColor(130,140,160); doc.setFontSize(6.5); doc.setFont('helvetica','normal');
    doc.text(name+'  ·  '+group+'  ·  Código: '+code+'  ·  Página '+p+'/'+pages,
      PW/2, PH-5, {align:'center'});
  }

  doc.save('econo_reflexion_' + name.replace(/\s+/g,'_') + '_' + group.replace(/\s+/g,'_') + '.pdf');
  btn.innerHTML = '⬇ &nbsp;Descargar Resultados PDF';
  btn.disabled  = false;
}

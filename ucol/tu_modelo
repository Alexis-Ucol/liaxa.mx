function checkProposalAndUnlock() {
  updateModelDisplay();
  var pq  = (document.getElementById('pq')||{value:''}).value.trim();
  var py  = (document.getElementById('py')||{value:''}).value.trim();
  var yl  = (document.getElementById('ylabel')||{value:''}).value.trim();
  var lim = (document.getElementById('limitation')||{value:''}).value.trim();
  // Need at least: research question, Y variable, Y label, 1 regressor, limitation
  var hasVar = false;
  for (var r = 0; r < 4; r++) {
    if ((document.getElementById('vname'+r)||{value:''}).value.trim()) { hasVar = true; break; }
  }
  var complete = pq && py && yl && lim && hasVar;
  var gate = document.getElementById('gatedSection');
  var msg  = document.getElementById('unlockMsg');
  if (gate) {
    if (complete) {
      gate.classList.add('unlocked');
      if (msg) msg.style.display = 'none';
    } else {
      gate.classList.remove('unlocked');
      if (msg) msg.style.display = 'block';
    }
  }
}

/* ════════════════════════════════════════════════
   SKETCH CANVAS HELPERS
   ════════════════════════════════════════════════ */
var sketchStates = {}; // keyed by canvasId

function initSketchCanvas(canvasId, toolbarId, isResid) {
  var canvas = document.getElementById(canvasId);
  if (!canvas) return;
  var dpr = window.devicePixelRatio || 1;
  // Always size to CSS pixel width (200px tall) regardless of display:none state
  var cssW = canvas.offsetWidth || canvas.parentElement.offsetWidth || 300;
  var cssH = 200;
  canvas.width  = cssW * dpr;
  canvas.height = cssH * dpr;
  var ctx = canvas.getContext('2d');
  ctx.scale(dpr, dpr);
  sketchStates[canvasId] = { tool: 'pen', ctx: ctx, dpr: dpr, isResid: !!isResid };

  function fullRedraw(yLbl, xLbl) {
    var w = canvas.width / dpr;
    var h = canvas.height / dpr;
    // White background
    ctx.save();
    ctx.globalCompositeOperation = 'source-over';
    ctx.globalAlpha = 1;
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, w, h);
    // Axes
    ctx.strokeStyle = '#b0aa9e';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(38, 10);     ctx.lineTo(38, h - 30);   ctx.stroke(); // Y axis
    ctx.beginPath(); ctx.moveTo(38, h - 30); ctx.lineTo(w - 10, h - 30); ctx.stroke(); // X axis
    ctx.beginPath(); ctx.moveTo(33,16); ctx.lineTo(38,8);    ctx.lineTo(43,16);    ctx.stroke(); // Y arrow
    ctx.beginPath(); ctx.moveTo(w-17,h-35); ctx.lineTo(w-9,h-30); ctx.lineTo(w-17,h-25); ctx.stroke(); // X arrow
    // Residual zero line — dashed horizontal in middle of plot area
    if (isResid) {
      var midY = (10 + h - 30) / 2;
      ctx.strokeStyle = '#c9a84c';
      ctx.lineWidth = 1;
      ctx.setLineDash([5, 4]);
      ctx.beginPath(); ctx.moveTo(42, midY); ctx.lineTo(w - 12, midY); ctx.stroke();
      ctx.setLineDash([]);
      // Label the zero line
      ctx.fillStyle = '#c9a84c';
      ctx.font = '9px IBM Plex Mono, monospace';
      ctx.textAlign = 'left';
      ctx.fillText('0', 26, midY + 3);
    }
    // Labels
    ctx.fillStyle = '#4a4640';
    ctx.font = 'bold 11px IBM Plex Sans, sans-serif';
    ctx.globalAlpha = 1;
    // Y label rotated
    ctx.save();
    ctx.translate(12, h / 2);
    ctx.rotate(-Math.PI / 2);
    ctx.textAlign = 'center';
    var yTxt = (yLbl||'Y').length > 14 ? (yLbl||'Y').slice(0,13)+'…' : (yLbl||'Y');
    ctx.fillText(yTxt, 0, 0);
    ctx.restore();
    // X label
    ctx.textAlign = 'center';
    var xTxt = (xLbl||'X').length > 18 ? (xLbl||'X').slice(0,17)+'…' : (xLbl||'X');
    ctx.fillText(xTxt, (38 + w - 10) / 2, h - 10);
    ctx.restore();
  }

  canvas._drawBase = function(yLbl, xLbl) {
    canvas._yLabel = yLbl;
    canvas._xLabel = xLbl;
    fullRedraw(yLbl, xLbl);
  };
  canvas._drawBase(canvas._yLabel || 'Y', canvas._xLabel || 'X');

  var drawing = false, lx = 0, ly = 0;
  function getPos(e) {
    var r = canvas.getBoundingClientRect();
    var src = e.touches ? e.touches[0] : e;
    return [src.clientX - r.left, src.clientY - r.top];
  }
  function onDown(e) {
    e.preventDefault(); drawing = true;
    var p = getPos(e); lx = p[0]; ly = p[1];
    var st = sketchStates[canvasId];
    ctx.globalAlpha = 1;
    if (st.tool === 'eraser') {
      ctx.globalCompositeOperation = 'destination-out';
      ctx.lineWidth = 18;
    } else {
      ctx.globalCompositeOperation = 'source-over';
      ctx.strokeStyle = '#2d5a27';
      ctx.lineWidth = 2;
    }
  }
  function onMove(e) {
    e.preventDefault();
    if (!drawing) return;
    var p = getPos(e);
    ctx.beginPath(); ctx.moveTo(lx, ly); ctx.lineTo(p[0], p[1]); ctx.stroke();
    lx = p[0]; ly = p[1];
  }
  function onUp() { drawing = false; saveSession(); }
  canvas.addEventListener('mousedown',  onDown, { passive: false });
  canvas.addEventListener('mousemove',  onMove, { passive: false });
  canvas.addEventListener('mouseup',    onUp);
  canvas.addEventListener('mouseleave', onUp);
  canvas.addEventListener('touchstart', onDown, { passive: false });
  canvas.addEventListener('touchmove',  onMove, { passive: false });
  canvas.addEventListener('touchend',   onUp);
}

function setSketchTool(canvasId, tool, btn) {
  if (sketchStates[canvasId]) sketchStates[canvasId].tool = tool;
  var tb = document.getElementById(canvasId).closest('.sketch-wrap').querySelector('.sketch-toolbar');
  if (tb) tb.querySelectorAll('.tbtn2').forEach(function(b) { b.classList.remove('on'); });
  if (btn) btn.classList.add('on');
}

function clearSketch(canvasId) {
  var canvas = document.getElementById(canvasId);
  if (!canvas) return;
  var dpr = window.devicePixelRatio || 1;
  var ctx = canvas.getContext('2d');
  ctx.clearRect(0, 0, canvas.width / dpr, canvas.height / dpr);
  if (canvas._drawBase) {
    var yLbl = canvas._yLabel || 'Y';
    var xLbl = canvas._xLabel || 'X';
    canvas._drawBase(yLbl, xLbl);
  }
  saveSession();
}

var _sketchDebounce = null;
function updateSketchLabels() {
  clearTimeout(_sketchDebounce);
  _sketchDebounce = setTimeout(function() {
    var yLbl = (document.getElementById('ylabel') || { value: 'Y' }).value.trim() || 'Y';
    for (var r = 0; r < 4; r++) {
      var nm = (document.getElementById('vname' + r) || { value: '' }).value.trim();
      var canvas = document.getElementById('sketchScat' + r);
      if (!canvas) continue;
      var wrap = document.getElementById('sketchWrap' + r);
      if (!nm) {
        if (wrap) wrap.style.display = 'none';
        continue;
      }
      var wasHidden = wrap && wrap.style.display === 'none';
      if (wrap) wrap.style.display = '';
      // If canvas was previously 0-sized (was hidden on init), resize it now
      var dpr = window.devicePixelRatio || 1;
      var cssW = canvas.offsetWidth || canvas.parentElement.offsetWidth || 300;
      if (canvas.width < 10 || wasHidden) {
        canvas.width  = cssW * dpr;
        canvas.height = 200 * dpr;
        var ctx2 = canvas.getContext('2d');
        ctx2.scale(dpr, dpr);
        sketchStates['sketchScat' + r] = { tool: 'pen', ctx: ctx2, dpr: dpr, isResid: false };
      }
      canvas._yLabel = yLbl;
      canvas._xLabel = nm;
      if (canvas._drawBase) {
        canvas._drawBase(yLbl, nm);
      } else {
        // Re-init fully if _drawBase missing (canvas was hidden at init time)
        initSketchCanvas('sketchScat' + r, 'sketchTb' + r, false);
        canvas._yLabel = yLbl;
        canvas._xLabel = nm;
        if (canvas._drawBase) canvas._drawBase(yLbl, nm);
      }
    }
  }, 600);
}


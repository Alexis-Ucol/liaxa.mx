  problems.push({
    title: 'Correlación vs. causalidad',
    questionText: 'Supón que estimas tu modelo y encuentras que todos los coeficientes son estadísticamente significativos y el R² = 0.82. ¿Puedes concluir que las variables X <strong>causan</strong> los cambios en Y?',
    fn: '',
    options: r2.opts,
    correctIdx: r2.correctIdx,
    hint: 'Piensa en la limitación que escribiste en el Paso 4. ¿Podría algo en esa limitación afectar la interpretación causal?',
    explanation: 'MCO estándar estima asociaciones condicionales, no relaciones causales. Para inferencia causal se necesitan estrategias adicionales: variables instrumentales, diferencias en diferencias, diseños de discontinuidad de regresión, etc. Un R² alto solo indica buen ajuste, no causalidad.',
    studentChoice: null, pendingChoice: null
  });
  buildOneCard(problems[problems.length - 1], problems.length - 1);
  var card1 = document.getElementById('pc1');
  if (card1) s6wrapper.appendChild(card1);

  /* ── PROBLEMA 3 ── */
  var r3 = shuffleOpts(
    ['Multicolinealidad: dos X muy correlacionadas entre sí',
     'Heteroscedasticidad: la varianza de ε no es constante',
     'Autocorrelación positiva: los errores siguen un patrón en el tiempo',
     'Sesgo de selección: la muestra no es aleatoria'],
    'Heteroscedasticidad: la varianza de ε no es constante', rng
  );
  // Pick a random contextual framing based on the student's rng
  var hetScenarios = [
    'datos de ingresos que van desde trabajadores con salario mínimo hasta directivos corporativos',
    'precios de viviendas que van desde departamentos pequeños hasta residencias de lujo',
    'consumo eléctrico de hogares rurales y hogares en zonas industriales',
    'gasto mensual de estudiantes y de familias con múltiples ingresos'
  ];
  var scenario = hetScenarios[Math.floor(rng() * hetScenarios.length)];

  problems.push({
    title: 'Diagnóstico de tu modelo',
    questionText: 'Imagina que tu muestra incluye <strong>' + scenario + '</strong>. Al graficar los residuales contra los valores ajustados, notas que la dispersión de los residuales aumenta conforme Y aumenta. ¿Cuál problema econométrico describe esto?',
    fn: '',
    options: r3.opts,
    correctIdx: r3.correctIdx,
    hint: 'Recuerda el supuesto de MCO sobre la varianza del término de error: Var(ε|X) = σ². ¿Qué pasa cuando esa varianza no es constante?',
    explanation: 'Eso describe heteroscedasticidad: la varianza del error no es constante sino que depende del nivel de Y (o de alguna X). La consecuencia es que los errores estándar de MCO son incorrectos, haciendo inválidas las pruebas t y F. La corrección más común es usar errores estándar robustos (White).',
    studentChoice: null, pendingChoice: null
  });
  buildOneCard(problems[problems.length - 1], problems.length - 1);
  var card2 = document.getElementById('pc2');
  if (card2) s6wrapper.appendChild(card2);
}


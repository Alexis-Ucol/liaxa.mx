/* ================================================
   BUILD LESSON
   ================================================ */
function buildLesson(rng) {
  var lb = document.getElementById('lessonBody');

  function sec(html) {
    var d = document.createElement('div');
    d.className = 'section';
    d.innerHTML = html;
    lb.appendChild(d);
  }

  function rblock(code) {
    return '<div class="rblock">' +
      '<div class="rblock-hdr"><span>R</span>' +
      '<button class="rblock-copy" onclick="copyRCode(this)">Copiar</button></div>' +
      '<pre>' + code + '</pre></div>';
  }

  function stepBar(active) {
    var steps = ['1. Datos','2. Estacionariedad','3. ACF/PACF','4. Estimación','5. Diagnóstico','6. Pronóstico'];
    var html = '<div class="step-indicator">';
    steps.forEach(function(s, i) {
      if (i > 0) html += '<span class="step-arrow">›</span>';
      html += '<span class="step-pill ' + (i === active ? 'step-active' : 'step-dim') + '">' + s + '</span>';
    });
    return html + '</div>';
  }

  /* ────────────────────────────────────────────────
     GENERATE STUDENT-SPECIFIC SERIES
     Base: realistic USD/MXN path ~17.5–22.5 range
     Student noise layered on top via rng
  ──────────────────────────────────────────────── */
  var base = [17.52,17.61,17.74,17.88,17.95,18.03,18.22,18.41,18.55,18.63,
              18.71,18.82,18.94,19.08,19.21,19.35,19.42,19.28,19.15,19.07,
              19.18,19.32,19.47,19.55,19.68,19.81,19.94,20.08,20.19,20.31,
              20.44,20.58,20.71,20.85,20.96,21.08,21.19,21.28,21.35,21.44,
              21.53,21.62,21.71,21.82,21.90,21.98,22.10,22.21];

  var series = base.map(function(v) {
    return Math.round((v + (rng() - 0.5) * 0.55) * 100) / 100;
  });

  var lastVal = series[series.length - 1];

  // ── SCENARIO ASSIGNMENT (seeded, 4 types) ──
  var scenarios = [
    {
      id: 0,
      icon: '🏭',
      nombre: 'Importador de maquinaria',
      desc: 'Tu empresa necesita comprar <strong>USD $80,000</strong> para pagar maquinaria industrial que llegará en 3 meses.',
      logica: 'Si el tipo de cambio <em>sube</em> (peso se deprecia), comprar dólares <strong>ahora</strong> es más barato. Si el tipo de cambio <em>baja</em> (peso se aprecia), conviene <strong>esperar</strong>.',
      accion: 'Decidir: ¿comprar los dólares hoy o en 3 meses?',
      promptExtra: '¿Tu pronóstico indica que el peso se apreciará o se depreciará? ¿Cuánto costarían los USD $80,000 al tipo de cambio actual vs. al pronosticado? ¿Cuál es tu recomendación y por qué?'
    },
    {
      id: 1,
      icon: '🌽',
      nombre: 'Exportador agroindustrial',
      desc: 'Tu empresa recibirá el pago de una exportación de <strong>USD $120,000</strong> en 3 meses.',
      logica: 'Si el tipo de cambio <em>sube</em> (peso se deprecia), convertir los dólares más tarde te da <strong>más pesos</strong>. Si el tipo de cambio <em>baja</em>, conviene <strong>convertir ahora</strong> con un contrato forward.',
      accion: 'Decidir: ¿fijar el tipo de cambio hoy (forward) o convertir al tipo spot en 3 meses?',
      promptExtra: '¿Tu pronóstico sugiere que recibirás más o menos pesos por esos USD $120,000 si esperas? Calcula la diferencia aproximada. ¿Qué recomiendas y por qué?'
    },
    {
      id: 2,
      icon: '✈️',
      nombre: 'Agencia de viajes',
      desc: 'Tu agencia debe pagar <strong>USD $35,000</strong> a un proveedor de tours internacionales en 3 meses.',
      logica: 'Si el tipo de cambio <em>sube</em>, el costo en pesos de ese pago <strong>aumenta</strong> — conviene cubrir el riesgo hoy. Si el tipo de cambio <em>baja</em>, podrías ahorrar <strong>esperando</strong>.',
      accion: 'Decidir: ¿contratar un seguro cambiario hoy o asumir el riesgo y pagar al tipo spot en 3 meses?',
      promptExtra: '¿Cuánto más (o menos) pagarías en pesos si el tipo de cambio llega al valor pronosticado? ¿Vale la pena pagar la prima del seguro? Justifica tu respuesta.'
    },
    {
      id: 3,
      icon: '🏦',
      nombre: 'Tesorero corporativo',
      desc: 'Tu empresa tiene reservas de <strong>MXN $2,000,000</strong>. Debes decidir si convertir parte de ellas a dólares como cobertura.',
      logica: 'Si el tipo de cambio <em>sube</em> (el dólar se encarece), convertir pesos a dólares <strong>hoy</strong> protege el valor de las reservas. Si el tipo de cambio <em>baja</em>, conviene <strong>mantener en pesos</strong>.',
      accion: 'Decidir: ¿convertir MXN $1,000,000 a dólares hoy o mantener la posición en pesos?',
      promptExtra: '¿Cuántos dólares obtendrías hoy con MXN $1,000,000? ¿Y con el tipo de cambio pronosticado? ¿Qué decisión maximiza el valor de las reservas?'
    }
  ];

  var scenIdx = Math.floor(rng() * 4);
  var sc = scenarios[scenIdx];
  scenarioData = sc;

  var seriesStr = series.join(', ');

  /* ════════════════════════════════════════
     INTRODUCCIÓN + ESCENARIO PERSONAL
  ════════════════════════════════════════ */
  sec('<div class="stag">Examen Final Práctico · Ciclo Box-Jenkins</div>' +
      '<h2>Tu misión de hoy</h2>' +
      '<p>Vas a recorrer el <strong>Ciclo Box-Jenkins completo</strong> con una serie real de tipo de cambio ' +
      'USD/MXN. No hay respuestas esperadas en pantalla — tú corres el código en R, interpretas tu propia ' +
      'salida, y llegas a tus propias conclusiones.</p>' +
      '<p>Al final, usarás tu pronóstico para tomar una <strong>decisión de negocio concreta</strong>.</p>' +
      '<div class="refcard">' +
        '<div class="refcard-hdr">' +
          '<div class="refcard-ico">' + sc.icon + '</div>' +
          '<div><div class="refcard-title">Tu escenario: ' + sc.nombre + '</div>' +
          '<div class="refcard-sub">' + sc.accion + '</div></div>' +
        '</div>' +
        '<p style="font-size:.88rem;color:var(--text2);margin-bottom:.6rem">' + sc.desc + '</p>' +
        '<div class="callout-gold"><p><strong>Lógica de decisión:</strong> ' + sc.logica + '</p></div>' +
      '</div>' +
      '<p style="margin-top:1rem;font-size:.84rem;color:var(--text3)">Sigue los pasos en orden. Cada bloque de R corresponde exactamente a una etapa del ciclo.</p>');

  /* ════════════════════════════════════════
     PASO 1 — CARGAR Y GRAFICAR
  ════════════════════════════════════════ */
  sec(stepBar(0) +
      '<div class="stag">Paso 1 · Exploración inicial</div>' +
      '<h2>Carga tu serie y grafícala</h2>' +
      '<p>Tu serie contiene <strong>48 observaciones mensuales</strong> de tipo de cambio USD/MXN ' +
      '(enero 2020 – diciembre 2023). Carga los datos y genera la gráfica de tiempo.</p>' +
      '<div class="callout"><strong>¿Qué buscar?</strong><p>' +
      'Una serie <em>estacionaria</em> oscila alrededor de un nivel constante sin tendencia visible. ' +
      'Una serie <em>no estacionaria</em> muestra una dirección sostenida hacia arriba o abajo, ' +
      'o varianza que cambia con el tiempo.</p></div>' +
      rblock(
'# ── Tu serie personal USD/MXN (48 meses) ──\ntc <- c(' + seriesStr + ')\n\n# Convertir a objeto ts (inicio: enero 2020)\ntc_ts <- ts(tc, start=c(2020,1), frequency=12)\n\n# Graficar\nplot(tc_ts,\n     main="Tipo de Cambio USD/MXN",\n     ylab="MXN por USD", xlab="Tiempo",\n     col="steelblue", lwd=2)\nabline(h=mean(tc_ts), col="firebrick", lty=2)\nlegend("topleft", legend="Media global", col="firebrick", lty=2, bty="n")'
      ) +
      '<p style="font-size:.84rem;color:var(--text3);margin-top:.5rem">📌 Pega o fotografía tu gráfica en el área de trabajo de la pregunta siguiente.</p>');

  /* Problem 1 */
  var p1 = shuffleOpts(
    ['No — hay una tendencia ascendente visible, la media no es constante',
     'Sí — la serie oscila alrededor de un nivel constante sin dirección',
     'No se puede determinar solo con la gráfica',
     'Sí — cualquier serie de tipo de cambio es estacionaria por definición'],
    'No — hay una tendencia ascendente visible, la media no es constante', rng);
  problems.push({
    title: 'Inspección visual de la serie',
    questionText: 'Observa tu gráfica. La línea de media global (roja punteada), ¿cruza el centro de la serie en todo momento, o queda por debajo al inicio y por arriba al final (o viceversa)? Con base en eso, ¿tu serie parece estacionaria?',
    fn: '',
    options: p1.opts, correctIdx: p1.correctIdx,
    explanation: 'Una serie no estacionaria tiene una media que cambia con el tiempo — la línea de media global no divide la serie simétricamente. Si la serie "sube" de forma sostenida (tendencia), la media global queda por debajo en los primeros períodos y por encima al final. Ese patrón confirma no estacionariedad.',
    hint: 'Fíjate si la serie "cruza" la línea punteada varias veces de manera simétrica, o si casi nunca la toca en un extremo y la supera constantemente en el otro.',
    studentChoice: null, pendingChoice: null
  });
  buildOneCard(problems[problems.length-1], problems.length-1);

  /* ════════════════════════════════════════
     PASO 2 — PRUEBA ADF EN NIVELES
  ════════════════════════════════════════ */
  sec(stepBar(1) +
      '<div class="stag">Paso 2 · Prueba formal de estacionariedad</div>' +
      '<h2>Prueba ADF en niveles</h2>' +
      '<p>La gráfica da una primera impresión, pero necesitamos confirmación estadística. ' +
      'La <strong>Prueba Aumentada de Dickey-Fuller (ADF)</strong> contrasta formalmente si existe raíz unitaria.</p>' +
      '<div class="callout"><strong>Regla de decisión ADF</strong><p>' +
      '<strong>H₀:</strong> la serie tiene raíz unitaria → no es estacionaria.<br>' +
      '<strong>H₁:</strong> la serie es estacionaria.<br><br>' +
      'Si p-valor &lt; 0.05 → rechazamos H₀ → la serie <em>es</em> estacionaria → <strong>d = 0</strong><br>' +
      'Si p-valor ≥ 0.05 → no rechazamos H₀ → la serie <em>no es</em> estacionaria → hay que diferenciar' +
      '</p></div>' +
      rblock(
'# Instalar si no lo tienes: install.packages("tseries")\nlibrary(tseries)\n\n# ADF sobre la serie en niveles\nadf.test(tc_ts)\n\n# Registra: estadístico Dickey-Fuller y p-valor'
      ));

  var p2 = shuffleOpts(
    ['p ≥ 0.05 — no rechazamos H₀, la serie no es estacionaria, d ≥ 1',
     'p < 0.05 — rechazamos H₀, la serie ya es estacionaria, d = 0',
     'El p-valor no importa; la gráfica ya confirmó la respuesta',
     'p ≥ 0.05 — rechazamos H₀, hay que diferenciar dos veces'],
    'p ≥ 0.05 — no rechazamos H₀, la serie no es estacionaria, d ≥ 1', rng);
  problems.push({
    title: 'Interpretación de la ADF en niveles',
    questionText: 'Ejecuta la ADF sobre tc_ts. Para una serie de tipo de cambio con tendencia, ¿qué resultado esperas obtener y qué significa para el parámetro d?',
    fn: 'Usa el resultado real de tu R',
    options: p2.opts, correctIdx: p2.correctIdx,
    explanation: 'Las series de tipo de cambio típicamente tienen raíz unitaria — el p-valor ADF suele ser alto (> 0.05), indicando que no podemos rechazar H₀. Esto confirma no estacionariedad y que necesitamos al menos una diferencia (d ≥ 1). Si tu p-valor es < 0.05, la serie sería excepcionalmente estacionaria en niveles — poco común en FX.',
    hint: 'Con p ≥ 0.05 NO rechazamos H₀. H₀ dice "hay raíz unitaria = no estacionaria". Entonces la serie no es estacionaria y d ≥ 1.',
    studentChoice: null, pendingChoice: null
  });
  buildOneCard(problems[problems.length-1], problems.length-1);

  /* ════════════════════════════════════════
     PASO 3 — PRIMERA DIFERENCIA + ADF
  ════════════════════════════════════════ */
  sec(stepBar(1) +
      '<div class="stag">Paso 2 (cont.) · Diferenciación</div>' +
      '<h2>Primera diferencia y verificación</h2>' +
      '<p>Si la ADF en niveles confirmó no estacionariedad, tomamos la <strong>primera diferencia</strong>: ' +
      '∆TC<sub>t</sub> = TC<sub>t</sub> − TC<sub>t−1</sub>. Esto convierte el tipo de cambio en ' +
      '<em>variación diaria del peso frente al dólar</em> — mucho más cercano a un proceso estacionario.</p>' +
      '<p>Luego repetimos la ADF para confirmar que logramos estacionariedad.</p>' +
      rblock(
'# Primera diferencia\ndtc <- diff(tc_ts)\n\n# Graficar la serie diferenciada\nplot(dtc,\n     main="Primera diferencia — ∆USD/MXN",\n     ylab="Cambio en tipo de cambio", xlab="Tiempo",\n     col="darkgreen", lwd=2)\nabline(h=0, col="firebrick", lty=2)\n\n# ADF sobre la primera diferencia\nadf.test(dtc)\n\n# ¿El p-valor es ahora < 0.05?'
      ));

  var p3 = shuffleOpts(
    ['d = 1 — una diferencia fue suficiente para lograr estacionariedad',
     'd = 0 — la serie en niveles ya era estacionaria',
     'd = 2 — siempre se necesitan dos diferencias para el tipo de cambio',
     'd = 1 — pero habría que confirmar también con la prueba KPSS'],
    'd = 1 — una diferencia fue suficiente para lograr estacionariedad', rng);
  problems.push({
    title: 'Determinación de d',
    questionText: 'Después de aplicar diff(), la ADF sobre dtc arroja p-valor < 0.05. ¿Qué valor de d corresponde para tu modelo ARIMA?',
    fn: 'ADF en ∆TC: p < 0.05',
    options: p3.opts, correctIdx: p3.correctIdx,
    explanation: 'Si la ADF en la primera diferencia da p < 0.05, rechazamos H₀ — la serie diferenciada es estacionaria. Eso significa que una sola diferencia fue suficiente, por lo tanto d = 1. El modelo tendrá la forma ARIMA(p, 1, q).',
    hint: 'd cuenta cuántas veces hay que diferenciar para alcanzar estacionariedad. Si una diferencia basta, d = 1.',
    studentChoice: null, pendingChoice: null
  });
  buildOneCard(problems[problems.length-1], problems.length-1);

  /* ════════════════════════════════════════
     PASO 4 — ACF Y PACF
  ════════════════════════════════════════ */
  sec(stepBar(2) +
      '<div class="stag">Paso 3 · Identificación de p y q</div>' +
      '<h2>ACF y PACF de la serie diferenciada</h2>' +
      '<p>Ahora que <code>dtc</code> es estacionaria, graficamos la <strong>ACF</strong> y la <strong>PACF</strong> ' +
      'para identificar los órdenes autorregresivo (p) y de media móvil (q).</p>' +
      '<div class="callout"><strong>Guía de identificación</strong><p>' +
      'Observa las barras que <em>sobresalen</em> de las bandas de significancia (líneas azules punteadas en R):<br><br>' +
      '• <strong>PACF se corta en lag k, ACF decae gradualmente</strong> → proceso AR(k) → p = k, q = 0<br>' +
      '• <strong>ACF se corta en lag k, PACF decae gradualmente</strong> → proceso MA(k) → p = 0, q = k<br>' +
      '• <strong>Ambas decaen gradualmente</strong> → proceso ARMA(p,q) → experimenta con p y q pequeños<br>' +
      '• <strong>Ninguna barra significativa</strong> → posible ruido blanco → verifica que d sea correcto' +
      '</p></div>' +
      rblock(
'# ACF y PACF de la primera diferencia\npar(mfrow=c(1,2))\nacf(dtc,  main="ACF — ∆USD/MXN",  lag.max=16)\npacf(dtc, main="PACF — ∆USD/MXN", lag.max=16)\npar(mfrow=c(1,1))\n\n# ¿En qué lags hay barras significativas?\n# ¿Cuál se corta y cuál decae?'
      ) +
      '<p style="font-size:.84rem;color:var(--text3);margin-top:.5rem">📌 Fotografía o dibuja tus ACF/PACF — las necesitarás para justificar tu elección de modelo.</p>');

  var p4 = shuffleOpts(
    ['PACF se corta en lag 1, ACF decae → AR(1) → modelo candidato ARIMA(1,1,0)',
     'ACF se corta en lag 1, PACF decae → MA(1) → modelo candidato ARIMA(0,1,1)',
     'Ambas se cortan en lag 1 → ARMA(1,1) → modelo candidato ARIMA(1,1,1)',
     'Ninguna barra es significativa → ARIMA(0,1,0) — caminata aleatoria'],
    'PACF se corta en lag 1, ACF decae → AR(1) → modelo candidato ARIMA(1,1,0)', rng);
  problems.push({
    title: 'Identificación del modelo candidato',
    questionText: 'Observa tus gráficas de ACF y PACF. El patrón más común en tipos de cambio es una PACF que se corta abruptamente en lag 1 mientras la ACF decae gradualmente. Si ves ese patrón, ¿qué modelo candidato señala?',
    fn: 'Usa la guía de identificación de arriba',
    options: p4.opts, correctIdx: p4.correctIdx,
    explanation: 'PACF cortándose en lag 1 + ACF decayendo es la firma de un proceso AR(1). Con d = 1 ya determinado, el modelo completo es ARIMA(1,1,0). Si tu ACF/PACF muestra un patrón diferente, el modelo correcto para ti puede ser distinto — lo importante es que tu elección sea consistente con lo que observas.',
    hint: 'La función que SE CORTA define el componente dominante: PACF se corta → AR. ACF se corta → MA.',
    studentChoice: null, pendingChoice: null
  });
  buildOneCard(problems[problems.length-1], problems.length-1);

  /* ════════════════════════════════════════
     PASO 5 — ESTIMACIÓN
  ════════════════════════════════════════ */
  sec(stepBar(3) +
      '<div class="stag">Paso 4 · Estimación</div>' +
      '<h2>Ajuste del modelo ARIMA</h2>' +
      '<p>Con p, d, q identificados, ajusta el modelo. Si tu ACF/PACF sugirió ARIMA(1,1,0), ' +
      'usa <code>order=c(1,1,0)</code>. Si identificaste otro modelo, ajusta el vector en consecuencia.</p>' +
      '<div class="callout"><strong>¿Qué revisar en la salida?</strong><p>' +
      'Observa el <strong>coeficiente estimado</strong> (ar1 o ma1) y su <strong>error estándar</strong>. ' +
      'Si |coeficiente / s.e.| &gt; 2, el parámetro es estadísticamente significativo al ~5%. ' +
      'También anota el <strong>AIC</strong> — si comparas modelos alternativos, elige el de menor AIC.' +
      '</p></div>' +
      rblock(
'# Ajustar ARIMA — cambia p,d,q según tu identificación\nmodelo <- arima(tc_ts, order=c(1,1,0))\n\n# Ver resultados\nsummary(modelo)\n\n# ¿El coeficiente es significativo?\n# t = coeficiente / s.e.  →  ¿|t| > 2?\ncoef(modelo)\n\n# AIC del modelo\nmodelo$aic'
      ));

  var p5 = shuffleOpts(
    ['|t| > 2 → el coeficiente es estadísticamente significativo y aporta al modelo',
     '|t| > 2 → el coeficiente no es significativo y debe eliminarse del modelo',
     '|t| < 2 → el coeficiente es significativo a un nivel de confianza mayor',
     'El estadístico t no aplica para modelos ARIMA, solo para regresión lineal'],
    '|t| > 2 → el coeficiente es estadísticamente significativo y aporta al modelo', rng);
  problems.push({
    title: 'Significancia del coeficiente estimado',
    questionText: 'Tu modelo devuelve un coeficiente con valor estimado y su error estándar. Calculas t = coeficiente / s.e. y obtienes un valor con |t| > 2. ¿Qué significa esto?',
    fn: 't = coeficiente ÷ s.e.',
    options: p5.opts, correctIdx: p5.correctIdx,
    explanation: '|t| > 2 equivale aproximadamente a un p-valor < 0.05 (para muestras moderadas). Significa que el coeficiente es estadísticamente distinguible de cero — el componente AR o MA que representa realmente contribuye a explicar la dinámica de la serie.',
    hint: 'La regla práctica: si el valor absoluto del estadístico t supera 2, el parámetro es significativo al ~5%.',
    studentChoice: null, pendingChoice: null
  });
  buildOneCard(problems[problems.length-1], problems.length-1);

  /* ════════════════════════════════════════
     PASO 6 — DIAGNÓSTICO
  ════════════════════════════════════════ */
  sec(stepBar(4) +
      '<div class="stag">Paso 5 · Diagnóstico de residuos</div>' +
      '<h2>¿Los residuos son ruido blanco?</h2>' +
      '<p>El modelo es válido solo si sus <strong>residuos no muestran estructura autocorrelacionada</strong>. ' +
      'Si quedan patrones, el modelo está incompleto y los pronósticos serán sesgados.</p>' +
      '<p>Realizamos tres verificaciones:</p>' +
      '<div class="rules-grid">' +
        '<div class="rcard"><div class="rname">Verificación 1</div><div class="rform">Gráfica de residuos</div><div class="rnote">Deben oscilar alrededor de cero, sin tendencia ni varianza creciente.</div></div>' +
        '<div class="rcard"><div class="rname">Verificación 2</div><div class="rform">ACF de residuos</div><div class="rnote">Ninguna barra debe salir de las bandas de significancia.</div></div>' +
        '<div class="rcard"><div class="rname">Verificación 3</div><div class="rform">Prueba Ljung-Box</div><div class="rnote">H₀: residuos independientes. Queremos p-valor &gt; 0.05.</div></div>' +
      '</div>' +
      rblock(
'# Extraer y analizar residuos\nres <- modelo$residuals\n\n# Gráfica\nplot(res, main="Residuos del modelo ARIMA",\n     col="darkblue", lwd=1.5)\nabline(h=0, col="red", lty=2)\n\n# ACF de residuos\nacf(res, main="ACF — Residuos", lag.max=16)\n\n# Prueba de Ljung-Box (10 rezagos)\nBox.test(res, lag=10, type="Ljung-Box")\n\n# p-valor > 0.05 → residuos son ruido blanco ✓\n# p-valor < 0.05 → hay estructura residual → ajustar p o q'
      ));

  var p6 = shuffleOpts(
    ['Regresar a la etapa de identificación y ajustar p o q del modelo',
     'Aumentar d en 1 — los residuos autocorrelacionados indican más diferenciación',
     'Aceptar el modelo de todas formas — algún grado de autocorrelación es normal',
     'Cambiar el nivel α de la prueba a 0.01 para que el modelo pase'],
    'Regresar a la etapa de identificación y ajustar p o q del modelo', rng);
  problems.push({
    title: 'Diagnóstico: modelo rechazado',
    questionText: 'La prueba de Ljung-Box devuelve p-valor = 0.03 sobre los residuos de tu ARIMA. ¿Qué acción corresponde?',
    fn: 'H₀ Ljung-Box: residuos son independientes',
    options: p6.opts, correctIdx: p6.correctIdx,
    explanation: 'p = 0.03 < 0.05 → rechazamos H₀ → hay autocorrelación residual. El modelo no capturó toda la estructura de la serie. La acción correcta es volver a la identificación: quizás p o q están subestimados. Por ejemplo, si usaste ARIMA(1,1,0) y falla, prueba ARIMA(2,1,0) o ARIMA(1,1,1). Aumentar d sería incorrecto — ya logramos estacionariedad con d=1.',
    hint: 'Ljung-Box p < 0.05 = hay autocorrelación que el modelo no explicó. ¿Qué etapa del ciclo determina p y q?',
    studentChoice: null, pendingChoice: null
  });
  buildOneCard(problems[problems.length-1], problems.length-1);

  /* ════════════════════════════════════════
     PASO 7 — PRONÓSTICO
  ════════════════════════════════════════ */
  sec(stepBar(5) +
      '<div class="stag">Paso 6 · Pronóstico</div>' +
      '<h2>Pronóstico a 3 meses</h2>' +
      '<p>Si el diagnóstico pasó, generamos las predicciones para los <strong>3 meses siguientes</strong>. ' +
      'El paquete <code>forecast</code> produce el pronóstico puntual más intervalos al 80% y 95%.</p>' +
      '<div class="callout-gold"><strong>¿Por qué los intervalos se amplían?</strong><p>' +
      'Cada mes adicional de pronóstico acumula la incertidumbre de todos los períodos previos. ' +
      'El intervalo del mes 3 es más ancho que el del mes 1 porque incorpora más fuentes de error. ' +
      'Esto no es un defecto — es una propiedad matemática fundamental.</p></div>' +
      rblock(
'# Instalar si no lo tienes: install.packages("forecast")\nlibrary(forecast)\n\n# Pronóstico 3 meses adelante\npred <- forecast(modelo, h=3)\nprint(pred)\n\n# Visualizar\nplot(pred,\n     main="Pronóstico USD/MXN — ARIMA",\n     ylab="MXN por USD", xlab="Tiempo",\n     shadecols=c("lightblue","steelblue"),\n     fcol="darkblue", lwd=2)\n\n# Tipo de cambio actual (último valor observado)\ncat("Tipo de cambio actual:", tail(tc, 1), "\\n")\ncat("Pronóstico mes 1:", pred$mean[1], "\\n")\ncat("Pronóstico mes 2:", pred$mean[2], "\\n")\ncat("Pronóstico mes 3:", pred$mean[3], "\\n")'
      ) +
      '<p style="font-size:.84rem;color:var(--text3);margin-top:.5rem">📌 Anota el tipo de cambio actual (' + lastVal.toFixed(2) + ' MXN/USD en tu serie) y los tres valores pronosticados — los necesitarás para la reflexión final.</p>');

  var p7 = shuffleOpts(
    ['El pronóstico converge hacia la tendencia de largo plazo del modelo — los cambios son graduales',
     'El pronóstico oscila hacia arriba y abajo de forma aleatoria',
     'El pronóstico siempre converge a la media histórica de la serie en niveles',
     'Los tres pronósticos son idénticos — ARIMA predice valores constantes'],
    'El pronóstico converge hacia la tendencia de largo plazo del modelo — los cambios son graduales', rng);
  problems.push({
    title: 'Comportamiento del pronóstico ARIMA',
    questionText: 'Observa los tres valores pronosticados (meses 1, 2 y 3). En un ARIMA(1,1,0) con coeficiente AR positivo, ¿cómo se comportan los pronósticos a medida que avanza el horizonte?',
    fn: 'Coeficiente AR: 0 < φ < 1',
    options: p7.opts, correctIdx: p7.correctIdx,
    explanation: 'En un AR(1) con 0 < φ < 1, el pronóstico converge exponencialmente hacia la tendencia implícita del proceso diferenciado. Los cambios predichos se vuelven más pequeños conforme avanza el horizonte. No son idénticos ni oscilatorios, sino que "se apagan" gradualmente.',
    hint: 'Con φ positivo y menor a 1, el efecto del último valor observado se diluye con cada paso hacia el futuro.',
    studentChoice: null, pendingChoice: null
  });
  buildOneCard(problems[problems.length-1], problems.length-1);

  /* ════════════════════════════════════════
     EVALUACIÓN FINAL — 3 preguntas sin explicación
  ════════════════════════════════════════ */
  sec('<div class="stag">Evaluación Final</div>' +
      '<h2>Preguntas de integración</h2>' +
      '<p>Las siguientes tres preguntas cubren el ciclo completo sin apoyo adicional. ' +
      'Responde con base en lo que hiciste hoy.</p>');

  /* Final 1 */
  var f1 = shuffleOpts(
    ['Identificación → Estimación → Diagnóstico → Pronóstico',
     'Estimación → Identificación → Diagnóstico → Pronóstico',
     'Diferenciación → Estimación → ACF/PACF → Pronóstico',
     'Pronóstico → Diagnóstico → Estimación → Identificación'],
    'Identificación → Estimación → Diagnóstico → Pronóstico', rng);
  problems.push({
    title: 'Orden del Ciclo Box-Jenkins',
    questionText: '¿Cuál es el orden correcto de las cuatro etapas del Ciclo Box-Jenkins?',
    fn: '',
    options: f1.opts, correctIdx: f1.correctIdx,
    explanation: 'El ciclo siempre sigue: (1) Identificación — determinar d con ADF, luego p y q con ACF/PACF. (2) Estimación — ajustar el modelo por máxima verosimilitud. (3) Diagnóstico — verificar que los residuos sean ruido blanco. (4) Pronóstico — solo si el modelo pasó el diagnóstico. Saltarse el diagnóstico es el error más común.',
    hint: 'El ciclo empieza siempre explorando los datos, nunca ajustando directamente.',
    studentChoice: null, pendingChoice: null
  });
  buildOneCard(problems[problems.length-1], problems.length-1);

  /* Final 2 */
  var f2 = shuffleOpts(
    ['ADF p < 0.05 → rechazamos H₀ → la serie ya es estacionaria → d = 0',
     'ADF p < 0.05 → no rechazamos H₀ → hay que diferenciar → d = 1',
     'ADF p < 0.05 → la serie tiene raíz unitaria → d = 2',
     'ADF p < 0.05 → el resultado es inconcluso — se necesita otra prueba'],
    'ADF p < 0.05 → rechazamos H₀ → la serie ya es estacionaria → d = 0', rng);
  problems.push({
    title: 'Lectura correcta de la ADF',
    questionText: 'Aplicas la ADF directamente a una serie en niveles y obtienes p-valor = 0.008. ¿Qué concluyes sobre d?',
    fn: 'H₀ ADF: la serie tiene raíz unitaria',
    options: f2.opts, correctIdx: f2.correctIdx,
    explanation: 'p = 0.008 < 0.05 → rechazamos H₀ (raíz unitaria) → la serie en niveles ya es estacionaria → d = 0. El error clásico es confundir la dirección: rechazar H₀ en ADF significa que la serie ES estacionaria, no que necesita diferenciarse.',
    hint: 'Rechazar H₀ en ADF es la buena noticia: significa que la serie ya es estacionaria.',
    studentChoice: null, pendingChoice: null
  });
  buildOneCard(problems[problems.length-1], problems.length-1);

  /* Final 3 */
  var f3 = shuffleOpts(
    ['El intervalo crece porque cada paso acumula la incertidumbre de los errores previos',
     'El intervalo crece porque el modelo está mal especificado',
     'El intervalo es constante en un ARIMA bien ajustado; si crece hay un error',
     'El intervalo crece solo para horizontes mayores a 12 períodos'],
    'El intervalo crece porque cada paso acumula la incertidumbre de los errores previos', rng);
  problems.push({
    title: 'Amplitud de los intervalos de predicción',
    questionText: 'El intervalo de predicción al 95% para el mes 1 es más estrecho que para el mes 3. ¿Por qué se amplían los intervalos con el horizonte de pronóstico?',
    fn: '',
    options: f3.opts, correctIdx: f3.correctIdx,
    explanation: 'El error de pronóstico en el horizonte k depende de k innovaciones (errores). La varianza acumulada crece con k, por lo que el intervalo se amplía. En un AR(1): Var(error h=1) = σ², Var(error h=2) = σ²(1 + φ²), etc. Este crecimiento es una propiedad matemática, no un defecto del modelo.',
    hint: 'Cuanto más lejos miramos al futuro, más "pasos" de incertidumbre se acumulan.',
    studentChoice: null, pendingChoice: null
  });
  buildOneCard(problems[problems.length-1], problems.length-1);

  /* ════════════════════════════════════════
     REFLEXIÓN FINAL — DECISIÓN DE NEGOCIO
  ════════════════════════════════════════ */
  var refDiv = document.createElement('div');
  refDiv.className = 'section';
  refDiv.id = 'refSection';
  refDiv.innerHTML =
    '<div class="stag">Reflexión Final</div>' +
    '<h2>Tu decisión de negocio</h2>' +
    '<p>Ahora integra tu pronóstico con el escenario que te fue asignado. ' +
    'No hay respuesta correcta única — lo que importa es que tu recomendación sea <strong>coherente con tu modelo</strong>.</p>' +
    '<div class="refcard">' +
      '<div class="refcard-hdr">' +
        '<div class="refcard-ico">' + sc.icon + '</div>' +
        '<div><div class="refcard-title">' + sc.nombre + '</div>' +
        '<div class="refcard-sub">Tipo de cambio actual en tu serie: ' + lastVal.toFixed(2) + ' MXN/USD</div></div>' +
      '</div>' +
      '<p style="font-size:.88rem;color:var(--text2);margin-bottom:.8rem">' + sc.desc + '</p>' +
      '<div class="callout-gold"><p><strong>Recuerda:</strong> ' + sc.logica + '</p></div>' +
      '<ul class="ref-prompts">' +
        '<li>' + sc.promptExtra + '</li>' +
        '<li>¿Cuál es el intervalo de confianza al 95% de tu pronóstico para el mes 3? ¿Qué tan seguros podemos estar de la decisión?</li>' +
        '<li>¿Cambia tu recomendación si el tipo de cambio llega al límite superior del intervalo en lugar del pronóstico puntual?</li>' +
      '</ul>' +
      '<textarea class="reftextarea" id="refTextarea" placeholder="Escribe aquí tu análisis y recomendación (mínimo 4 oraciones)..." oninput="saveSession()"></textarea>' +
    '</div>';
  lb.appendChild(refDiv);
  setTimeout(function() { refDiv.classList.add('vis'); }, 100);
}
</script>
</body>
</html>
